  <category name="MIDI">
    <reapack name="MIDI Pitch Bend Remover - Pitch Bend Only.jsfx" type="effect">
      <metadata>
        <description><![CDATA[Removes incoming MIDI Pitch Bend messages and passes all other MIDI through unchanged.]]></description>
      </metadata>
      <version name="1.0.0" author="KRGSH" time="2026-05-28T00:00:00Z">
        <source>https://github.com/frankhildebrandt/KRGSH-Reaper-Scripts/raw/main/MIDI/MIDI%20Pitch%20Bend%20Remover%20-%20Pitch%20Bend%20Only.jsfx</source>
      </version>
    </reapack>
    <reapack name="MIDI Scale Helper.jsfx" type="effect">
      <metadata>
        <description><![CDATA[Maps incoming MIDI notes to a selected scale. White keys play the selected scale as if every key were C major. Black keys are quantized to the nearest scale tone.]]></description>
      </metadata>
      <version name="1.0.0" author="KRGSH" time="2026-05-28T00:00:00Z">
        <source>https://github.com/frankhildebrandt/KRGSH-Reaper-Scripts/raw/main/MIDI/MIDI%20Scale%20Helper.jsfx</source>
      </version>
    </reapack>
    <reapack name="MIDI Sustain Helper.jsfx" type="effect">
      <metadata>
        <description><![CDATA[Tracks all pitch classes played while sustain is active.
Releases CC64 briefly on new chord gestures or likely dissonant additions.
Fixed JSFX memory layout corruption.]]></description>
      </metadata>
      <version name="2.0.1" author="KRGSH" time="2026-05-28T00:00:00Z">
        <source>https://github.com/frankhildebrandt/KRGSH-Reaper-Scripts/raw/main/MIDI/MIDI%20Sustain%20Helper.jsfx</source>
      </version>
    </reapack>
  </category>
